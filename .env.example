# Supabase — https://app.supabase.com/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=
# Use either legacy anon key or the dashboard "publishable" key (not both required if one is set)
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=
# Server-only; never expose to the browser or client bundles
SUPABASE_SERVICE_ROLE_KEY=

# App session signing (e.g. openssl rand -base64 32)
AUTH_SECRET=
